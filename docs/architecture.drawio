                <mxCell id="28" value="&lt;b&gt;Fluxo de Execução:&lt;/b&gt;&lt;br&gt;&lt;br&gt;1. &lt;b&gt;Lambda&lt;/b&gt; — Ingestão Kaggle&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;retry: 3x · backoff: 2s&lt;br&gt;&lt;br&gt;2. &lt;b&gt;Glue Job Bronze&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;timeout: 130 min&lt;br&gt;&lt;br&gt;3. &lt;b&gt;Glue Job Silver&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;timeout: 130 min&lt;br&gt;&lt;br&gt;4. &lt;b&gt;Glue Python Shell Gold&lt;/b&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;timeout: 70 min&lt;br&gt;&lt;br&gt;Choice State: OK (200/207)&lt;br&gt;Choice State: Fail (500)" style="text;html=1;strokeColor=#9900ff;fillColor=#fbfbfb;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=11;rounded=1;arcSize=5;" parent="1" vertex="1">
