# Credenciais efêmeras do AWS Learner Lab
# ---
# Copie este arquivo como `.env` e preencha com os valores reais da tela
# "AWS Details" do Learner Lab. NÃO commite o arquivo `.env`.
#
# As credenciais mudam a cada nova sessão — atualize o .env sempre que
# iniciar o Learner Lab.

AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=ASIA...
AWS_SECRET_ACCESS_KEY=...
AWS_SESSION_TOKEN=...

# Credenciais da API do Kaggle
# Gere em: kaggle.com → Account → API → Create New Token
# O deploy_lambda.sh usa estes valores para criar/atualizar os parâmetros
# no SSM Parameter Store automaticamente.
KAGGLE_USERNAME=...
KAGGLE_KEY=...
